{
  "name": "guangxi-travel-v2.0",
  "version": "2.0.0",
  "description": "广西旅游达人 v2.0 - 全功能获客系统 (Cloudflare Workers + Pages)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev pages --kv=GUANGXI_KV --durable=GUANGXI_DURABLE",
    "build": "npm run build:worker && npm run build:pages",
    "build:worker": "esbuild worker/index.js --bundle --outfile=dist/worker.js --minify",
    "build:pages": "next build && next export",
    "deploy": "wrangler pages deploy pages --project-name=guangxi-travel-v2",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "lucia": "^3.2.0",
    "jose": "^5.2.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.0",
    "date-fns": "^3.6.0",
    "zod": "^3.23.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "feishu-bot": "^1.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.1",
    "esbuild": "^0.21.0",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.3",
    "wrangler": "^3.60.0",
    "tsx": "^4.7.0"
  }
}
