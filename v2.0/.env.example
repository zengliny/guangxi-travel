# Cloudflare Workers + Pages 配置
NODE_ENV=production

# 飞书机器人配置 (免费版)
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-bot-id
FEISHU_BOT_SECRET=your-bot-secret

# Cloudflare KV (免费)
KV_NAMESPACE_ID=your-kv-namespace-id

# Cloudflare D1 数据库 (免费)
D1_DATABASE_ID=your-d1-database-id

# JWT 密钥 (生成: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 应用配置
APP_URL=https://guangxi-travel.pages.dev
API_URL=https://api.your-worker.workers.dev
